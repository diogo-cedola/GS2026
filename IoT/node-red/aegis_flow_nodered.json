  {
    "id": "mqtt_status",
    "type": "mqtt in",
    "z": "tab_aegis",
    "name": "status",
    "topic": "fiap/aegis/RM00000/status",
    "qos": "0",
    "datatype": "json",
    "broker": "broker_aegis",
    "x": 120,
    "y": 340,
    "wires": [["status_fn"]]
  },
  {
    "id": "status_fn",
    "type": "function",
    "z": "tab_aegis",
    "name": "interpreta status",
    "func": "var s = msg.payload;\nvar conf = Math.round((s.confianca || 0) * 100) + \"%\";\nvar estado = { payload: s.estado + \"  (\" + conf + \")\" };\nvar modo = { payload: \"Modo: \" + s.modo + \"  |  Servo: \" + s.servo + \"\\u00b0\" };\nvar alerta = null;\nif (s.estado && s.estado !== \"NOMINAL\") {\n  alerta = { payload: \"\\u26a0\\ufe0f ALERTA: \" + s.estado + \" (\" + conf + \")\" };\n}\nreturn [estado, modo, alerta];",
    "outputs": 3,
    "noerr": 0,
    "x": 320,
    "y": 340,
    "wires": [["t_estado"], ["t_modo"], ["dbg_alerta"]]
  },
  {
    "id": "t_estado",
    "type": "ui_text",
    "z": "tab_aegis",
    "group": "grp_status",
    "order": 1,
    "width": "6",
    "height": "2",
    "name": "",
    "label": "Estado do habitat",
    "format": "{{msg.payload}}",
    "layout": "col-center",
    "x": 540,
    "y": 320,
    "wires": []
  },
  {
    "id": "t_modo",
