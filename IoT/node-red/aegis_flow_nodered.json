    "z": "tab_aegis",
    "name": "tendencia CO2",
    "group": "grp_tele",
    "order": 6,
    "width": "6",
    "height": "4",
    "label": "Tendencia CO2 (ppm)",
    "chartType": "line",
    "legend": "false",
    "xformat": "HH:mm:ss",
    "interpolate": "linear",
    "nodata": "aguardando dados",
    "dot": false,
    "ymin": "",
    "ymax": "",
