  {
    "id": "mqtt_tele",
    "type": "mqtt in",
    "z": "tab_aegis",
    "name": "telemetria",
    "topic": "fiap/aegis/RM00000/telemetria",
    "qos": "0",
    "datatype": "json",
    "broker": "broker_aegis",
    "x": 130,
    "y": 120,
    "wires": [["split_tele"]]
  },
  {
    "id": "split_tele",
    "type": "function",
    "z": "tab_aegis",
    "name": "separa medicoes",
    "func": "var d = msg.payload;\nreturn [\n  { payload: d.temp,     topic: \"Temperatura\" },\n  { payload: d.umid,     topic: \"Umidade\" },\n  { payload: d.pressao,  topic: \"Pressao\" },\n  { payload: d.co2,      topic: \"CO2\" },\n  { payload: d.radiacao, topic: \"Radiacao\" }\n];",
    "outputs": 5,
    "noerr": 0,
    "x": 330,
    "y": 120,
    "wires": [["g_temp"], ["g_umid"], ["g_pres"], ["g_co2", "chart_co2"], ["g_rad"]]
  },
  {
